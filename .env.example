# fastapi-saas-kit environment variables
# Copy this file to .env for local development and replace placeholders.

# App
APP_NAME="My FastAPI App"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Admin
ADMIN_EMAIL=admin@example.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_kit
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Auth provider
# Use "mock" for local development. Use "jwt" when wiring your own JWT issuer.
AUTH_PROVIDER=mock
AUTH_JWT_SECRET=replace-with-a-random-64-character-development-value
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRY_MINUTES=60

# Cache provider
# Use "memory" for local development. Use a shared cache adapter in multi-worker deployments.
CACHE_PROVIDER=memory

# Rate limiting
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_AUTHENTICATED=60

# Provider adapter
# Use "mock" for local development. Add real provider credentials only in an untracked .env file.
BILLING_PROVIDER=mock
